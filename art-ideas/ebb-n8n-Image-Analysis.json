    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse Qwen keyword output\nlet keywords = {};\ntry {\n  const raw = $json.message.content\n    .replace(/```json|```/g, '')\n    .trim();\n  keywords = JSON.parse(raw);\n} catch(e) {\n  keywords = {\n    keywords_functional: [],\n    keywords_aesthetic: [],\n    keywords_material: [],\n    keywords_era: [],\n    keywords_color: [],\n    keywords_flat: []\n  };\n}\n\nconst flat = keywords.keywords_flat || [];\nconst era = keywords.keywords_era || [];\nconst color = keywords.keywords_color || [];\n\nconst embedText = [\n  $json.alt || '',\n  $json.model_output?.room_type || '',\n  flat.join(', ')\n].filter(Boolean).join('. ');\n\nreturn {\n  json: {\n    embed_text: embedText,\n    metadata: {\n      stem: parseInt($json.stem),\n      avg_color: $json.avg_color,\n      alt: $json.alt,\n      photographer: $json.photographer,\n      room_type: $json.model_output?.room_type || '',\n      decade_markers: ($json.model_output?.decade_markers || []).join(', '),\n      dominant_color: $json.model_output?.color_scheme?.dominant || '',\n      mood: $json.model_output?.color_scheme?.mood || '',\n      keywords_flat: flat.join(', '),\n      keywords_era: era.join(', '),\n      keywords_color: color.join(', '),\n      keywords_functional: (keywords.keywords_functional || []).join(', '),\n      keywords_aesthetic: (keywords.keywords_aesthetic || []).join(', '),\n      keywords_material: (keywords.keywords_material || []).join(', '),\n      pexels_url: `https://images.pexels.com/photos/${$json.metadata.stem}/pexels-photo-${$json.metadata.stem}.jpeg`\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        208
      ],
      "id": "8bd01e26-f232-4d3a-a032-e69ca6c0bb8d",
      "name": "JSON Code Cleanup 2"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let raw = $json.message.content\n  .replace(/```json|```/g, '')\n  .trim();\n\n// Fix unquoted values (e.g. [1960s] or mood: warm)\nraw = raw.replace(/:\\s*([a-zA-Z0-9][a-zA-Z0-9\\s\\-]*?)([,\\n}\\]])/g, \n  (match, value, terminator) => {\n    const trimmed = value.trim();\n    // Skip if it looks like a number, boolean, or null\n    if (['true','false','null'].includes(trimmed) || !isNaN(trimmed)) {\n      return match;\n    }\n    return `: \"${trimmed}\"${terminator}`;\n  }\n);\n\n// Fix unquoted array elements (e.g. [\"1960s, 1970s] or [warm, cozy])\nraw = raw.replace(/\\[\\s*([^\"\\[\\]{}\\n][^,\\[\\]]*?)(\\s*[,\\]])/g,\n  (match, value, terminator) => {\n    const trimmed = value.trim();\n    if (['true','false','null'].includes(trimmed) || !isNaN(trimmed)) {\n      return match;\n    }\n    return `[\"${trimmed}\"${terminator}`;\n  }\n);\n// Fix mixed-quoted arrays: [\"1960s\", 1970s, 1980s] → [\"1960s\", \"1970s\", \"1980s\"]\nraw = raw.replace(/\\[([^\\[\\]]*)\\]/g, (match, inner) => {\n  const fixed = inner.split(',').map(element => {\n    const trimmed = element.trim();\n    // Already quoted, a number, boolean, or null — leave alone\n    if (\n      trimmed.startsWith('\"') || \n      trimmed.startsWith(\"'\") ||\n      !isNaN(trimmed) ||\n      ['true','false','null'].includes(trimmed) ||\n      trimmed === ''\n    ) {\n      return element;\n    }\n    // Unquoted string — wrap it\n    return ` \"${trimmed}\"`;\n  }).join(',');\n  return `[${fixed}]`;\n});\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  parsed = {\n    room_type: \"unknown\",\n    decade_markers: [],\n    furniture: [],\n    color_scheme: { dominant: \"\", accents: [], mood: \"\" },\n    textures: [],\n    keywords: [],\n    parse_error: e.message,\n    raw_content: raw\n  };\n}\n\nreturn {\n  json: {\n    stem: $json.data?.id?.toString() || 'unknown',\n    avg_color: $json.data?.avg_color || '',\n    alt: $json.data?.alt || '',\n    photographer: $json.data?.photographer || '',\n    model_output: parsed\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        208
      ],
      "id": "dbb0500e-4ab2-49ad-adaf-214567f0090b",
      "name": "JSON Code Cleanup 1"
    },
